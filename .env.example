# Clerk client
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Clerk server
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_JWT_KEY=

# Optional Clerk routing / custom-domain configuration
VITE_CLERK_PROXY_URL=
VITE_CLERK_DOMAIN=
CLERK_PROXY_URL=
CLERK_DOMAIN=

# Comma-separated allowed origins for Clerk token verification
CLERK_AUTHORIZED_PARTIES=https://your-app.vercel.app,https://your-custom-domain.com
APP_URL=https://your-custom-domain.com

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key

# Bedrock (required when AI_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret
# Required only when AWS_ACCESS_KEY_ID starts with ASIA.
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Bedrock Model Configuration
# Default: Claude 3.5 Haiku (fast, cost-effective) via inference profile
# Supported models (ensure model access is enabled in AWS Bedrock console):
#   Claude: us.anthropic.claude-3-5-haiku-20241022-v1:0 (default - inference profile)
#           us.anthropic.claude-3-5-sonnet-20241022-v2:0 (inference profile)
#           anthropic.claude-3-5-opus-20240229-v1:0
#   Meta:   us.meta.llama3-3-70b-instruct-v1:0 (inference profile)
#   Amazon: us.amazon.nova-micro-v1:0 (inference profile)
# Note: Newer models require inference profile ARNs (us.* prefix) instead of direct model IDs
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# Redis / Vercel KV
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_kv_rest_token
